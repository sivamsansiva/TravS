SECRET_KEY=your-django-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DB_NAME=travs_db
DB_USER=root
DB_PASSWORD=yourpassword
DB_HOST=localhost
DB_PORT=3306
CORS_ALLOWED_ORIGINS=http://localhost:5173
ACCESS_TOKEN_LIFETIME_MINUTES=15
REFRESH_TOKEN_LIFETIME_DAYS=7

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Production overrides (set these in Railway backend service Variables tab) ──
# DJANGO_SETTINGS_MODULE=config.settings.production
# DEBUG=False
# ALLOWED_HOSTS=<your-app>.up.railway.app
# CORS_ALLOWED_ORIGINS=https://travs.vercel.app
# DB_NAME=railway
# DB_USER=root
# DB_PASSWORD=<MYSQL_ROOT_PASSWORD from Railway MySQL service>
# DB_HOST=<RAILWAY_PRIVATE_DOMAIN of MySQL service>   ← use private domain inside Railway
# DB_PORT=3306
# CLOUDINARY_CLOUD_NAME=<same as local>
# CLOUDINARY_API_KEY=<same as local>
# CLOUDINARY_API_SECRET=<same as local>
